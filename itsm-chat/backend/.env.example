# ITSM Chat Backend Environment Variables

# Existing settings
ANTHROPIC_API_KEY=sk-ant-xxx
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_TOKEN=your-paperclip-api-token
DEFAULT_COMPANY_ID=your-company-uuid
ITSM_BASE_URL=https://itsm.mlinterviewnotes.com
API_PORT=8100

# Database settings
DATABASE_URL=postgresql+asyncpg://chat_user:password@localhost:5432/itsm_chat

# JWT Authentication settings
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Paperclip WebSocket (optional - auto-generated from PAPERCLIP_API_URL if not set)
# PAPERCLIP_WS_URL=ws://localhost:3100/api/companies/{company_id}/events/ws
