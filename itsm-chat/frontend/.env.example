# ITSM Chat Frontend Environment Variables

# API URL (defaults to /api for same-origin requests)
VITE_API_URL=/api

# WebSocket URL (defaults to auto-detect from window.location)
# VITE_WS_URL=wss://chat.mlinterviewnotes.com/api/ws

# Company ID for unauthenticated users
VITE_COMPANY_ID=your-company-uuid
